<script>
var _etfArPlan = '';
var _etfArCreateUrl = '<?= $block->escapeJs($createSessionUrl) ?>';
var _etfArPlansUrl  = '<?= $block->escapeJs($plansUrl) ?>';

function etfArEsc(s){ var d=document.createElement('div'); d.textContent=s==null?'':String(s); return d.innerHTML; }
function etfArFeatList(text){
    if(!text) return '<li>One-click reindex from admin</li><li>All index types, no CLI</li>';
    var t = String(text).replace(/^[^—-]*[—-]\s*/, '');
    var parts = t.split(/,\s*/).filter(function(x){return x.trim();}).slice(0,4);
    if(!parts.length) return '<li>One-click reindex from admin</li>';
    return parts.map(function(p){return '<li>'+etfArEsc(p.trim())+'</li>';}).join('');
}
function etfArRenderPlans(data){
    var wrap = document.getElementById('etf-ar-plans');
    var plans = (data && data.plans) || [];
    if(!plans.length){ etfArPlansError(); return; }
    var oneTime = (data.mode === 'one_time');
    var html = '';
    plans.forEach(function(p){
        var popular = (!oneTime && p.period === 'monthly');
        var title = oneTime ? (p.name || 'Lifetime License')
                   : ({week:'Weekly',month:'Monthly',year:'Yearly'}[p.period_label] || etfArEsc(p.name));
        var unit  = oneTime ? ' once' : ('/' + etfArEsc(p.period_label));
        var desc  = oneTime ? 'Pay once — never expires.'
                   : ({week:'Short-term or trying it out',month:'The standard plan for ongoing stores',year:'Best value — 2 months free'}[p.period_label] || '');
        var priceDisp = '$' + p.price + (oneTime ? ' once' : '/' + p.period_label);
        html += '<div class="etf-plan-card'+(popular?' popular':'')+'">'
              + (popular ? '<span class="etf-popular-badge">Most Popular</span>' : '')
              + (oneTime ? '<span class="etf-popular-badge">Lifetime</span>' : '')
              + '<p class="etf-plan-name">'+etfArEsc(title)+'</p>'
              + '<p class="etf-plan-price">$'+etfArEsc(p.price)+'<span>'+unit+'</span></p>'
              + '<p class="etf-plan-desc">'+etfArEsc(desc)+'</p>'
              + '<ul class="etf-plan-features">'+etfArFeatList(p.features)+'</ul>'
              + '<button class="etf-btn-sub" data-slug="'+etfArEsc(p.slug)+'" data-name="'+etfArEsc(title)+'" data-price="'+etfArEsc(priceDisp)+'">Choose '+etfArEsc(title)+' &rarr;</button>'
              + '</div>';
    });
    wrap.innerHTML = html;
    wrap.querySelectorAll('.etf-btn-sub').forEach(function(b){
        b.addEventListener('click', function(){ etfArSelectPlan(b.dataset.slug, b.dataset.name, b.dataset.price); });
    });
}
function etfArPlansError(){
    document.getElementById('etf-ar-plans').innerHTML =
      '<div style="grid-column:1/-1;text-align:center;color:rgba(255,255,255,.5);font-size:.85rem;padding:18px;">Plans are temporarily unavailable. Use the “enter license key” link below.</div>';
}
(function(){
    if(!_etfArPlansUrl){ etfArPlansError(); return; }
    fetch(_etfArPlansUrl, { headers:{ 'Accept':'application/json','ngrok-skip-browser-warning':'1' } })
      .then(function(r){ return r.json(); }).then(etfArRenderPlans).catch(etfArPlansError);
})();

function etfArSelectPlan(plan, name, price) {
    _etfArPlan = plan;
    document.getElementById('etf-ar-plan-name-label').textContent = name;
    document.getElementById('etf-ar-plan-price-label').textContent = price;
    var box = document.getElementById('etf-ar-checkout');
    box.style.display = 'block';
    box.scrollIntoView({behavior: 'smooth', block: 'start'});
    document.getElementById('etf-ar-name').focus();
}

function etfArBack() {
    document.getElementById('etf-ar-checkout').style.display = 'none';
    window.scrollTo({top: 0, behavior: 'smooth'});
}

async function etfArProceedToPayment() {
    var name  = document.getElementById('etf-ar-name').value.trim();
    var email = document.getElementById('etf-ar-email').value.trim();
    if (!name) { alert('Please enter your full name.'); document.getElementById('etf-ar-name').focus(); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { alert('Please enter a valid email address.'); document.getElementById('etf-ar-email').focus(); return; }

    var btn = document.getElementById('etf-ar-pay-btn');
    var orig = btn.textContent;
    btn.textContent = 'Creating payment session…';
    btn.disabled = true;

    try {
        var body = new URLSearchParams({
            plan: _etfArPlan, name: name, email: email,
            form_key: '<?= $block->escapeJs($block->getFormKey()) ?>'
        });
        var resp = await fetch(_etfArCreateUrl, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: body.toString()
        });
        var rawText = await resp.text();
        var data;
        try { data = JSON.parse(rawText); } catch(e) { alert('Server response: ' + rawText.substring(0,300)); btn.textContent=orig; btn.disabled=false; return; }

        if (data.error) { alert('Error: ' + data.error); btn.textContent=orig; btn.disabled=false; }
        else if (data.url) { btn.textContent='Redirecting to checkout…'; window.location.href=data.url; }
        else { alert('Unexpected response. Please try again.'); btn.textContent=orig; btn.disabled=false; }
    } catch(e) { alert('Network error: ' + e.message); btn.textContent=orig; btn.disabled=false; }
}
</script>
